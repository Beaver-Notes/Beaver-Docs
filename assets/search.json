---
---
[
  {% for doc in site.docs %}
    {
      "title": "{{ doc.title | escape }}",

      {% if doc.details %}
        "details": "{{ doc.details | strip_html }}",
      {% else %}
        "details": "",
      {% endif %}

      "content": {{ doc.content | jsonify }},

      "image": "",

      "url": "{{ site.baseurl }}{{ doc.url }}",
      "tags": "{{ doc.category | default: '' }}",
      "date": "{{ doc.date | default: '' }}"
    } {% unless forloop.last %},{% endunless %}
  {% endfor %}
]
